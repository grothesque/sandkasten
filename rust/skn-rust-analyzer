#!/bin/bash
#
# Run rust-analyzer under skn with defaults suitable for working on untrusted
# projects, especially with network access disabled by default.
#
# This wrapper intentionally stays small and mostly lets skn parse its own
# options.  Leading skn + options may be given before rust-analyzer arguments,
# e.g.:
#
#   skn-rust-analyzer +W ../dep
#   skn-rust-analyzer +T ~/.cargo
#   skn-rust-analyzer +N
#
# rust-analyzer itself is sandboxed.  Cargo, rustc, build scripts, proc macros,
# and tests launched by rust-analyzer inherit that sandbox, regardless of how
# rust-analyzer chooses to locate cargo.
#
# Without +N, the wrapper asks skn to set CARGO_NET_OFFLINE=true inside the
# sandbox.  This preserves the important separation between fetching
# dependencies with network access and analyzing/building without it.  If +N is
# given, network access is enabled and this wrapper does not set
# CARGO_NET_OFFLINE.
#
# The detected Cargo workspace is bound writable because rust-analyzer and cargo
# may need to write target files and other workspace-local state. If no Cargo
# workspace is detected, the current directory is bound read-only so
# rust-analyzer can still start with its usual no-workspace behavior without
# giving write access to an arbitrary launch directory.

set -euo pipefail

progname="${0##*/}"

append_path_var() {
    local var_name=$1
    local path=$2
    local value

    [[ -n $path && -e $path ]] || return 0

    value=${!var_name:-}
    case ":$value:" in
        *:"$path":*) ;;
        *) printf -v "$var_name" '%s' "${value:+$value:}$path" ;;
    esac
}

append_default_home_path_var() {
    local var_name=$1
    local override_var_name=$2
    local default_basename=$3
    local path=

    if [[ -n ${!override_var_name:-} ]]; then
        path=${!override_var_name}
    elif [[ -n ${HOME:-} ]]; then
        path=$HOME/$default_basename
    fi

    append_path_var "$var_name" "$path"
}

# Parses skn’s initial +S header block. This delegates option parsing to skn
# itself instead of mirroring skn’s option grammar here.
network_enabled_from_skn_show() {
    local line state=

    while IFS= read -r line; do
        [[ $line == skn:\ * ]] || break
        case $line in
            "skn: network "*) state=${line#"skn: network "}; break ;;
        esac
    done

    case $state in
        enabled) return 0 ;;
        disabled) return 1 ;;
        *) return 2 ;;
    esac
}

skn_args=(
    skn
    rust-analyzer
    +P
)

if workspace_manifest=$(cargo locate-project --workspace --message-format=plain 2>/dev/null); then
    workspace_dir=$(dirname -- "$workspace_manifest")
    skn_args+=(+W "$workspace_dir")
else
    skn_args+=(+R "$(pwd)")
fi

# If they exist, make cargo home writable and rustup home readable.
append_default_home_path_var SKN_BINDS CARGO_HOME .cargo
append_default_home_path_var SKN_RO_BINDS RUSTUP_HOME .rustup
export SKN_BINDS SKN_RO_BINDS

skn_show_status=0
skn_show_output=$("${skn_args[@]}" +S "$@") || skn_show_status=$?
if ((skn_show_status != 0)); then
    exit "$skn_show_status"
fi

if network_enabled_from_skn_show <<<"$skn_show_output"; then
    :
else
    case $? in
        1) skn_args+=(+E CARGO_NET_OFFLINE=true) ;;
        *) echo "$progname: internal error parsing skn +S output" >&2; exit 2 ;;
    esac
fi

exec "${skn_args[@]}" "$@"
