#!/bin/bash
#
# Run rust-analyzer under skn with defaults suitable for working on untrusted
# projects, especially with network access disabled by default.
#
# This wrapper intentionally stays small and mostly lets skn parse its own
# options.  Leading skn + options may be given before rust-analyzer arguments,
# e.g.:
#
#   skn-rust-analyzer +W ../dep
#   skn-rust-analyzer +T ~/.cargo
#
# rust-analyzer itself is sandboxed.  Cargo, rustc, build scripts, proc macros,
# and tests launched by rust-analyzer inherit that sandbox, regardless of how
# rust-analyzer chooses to locate cargo.
#
# The wrapper asks skn to set CARGO_NET_OFFLINE=true inside the sandbox. This
# preserves the important separation between fetching dependencies with network
# access and analyzing/building without it. +N is refused because rust-analyzer
# can execute build scripts, proc macros, tests, and other project code through
# Cargo subprocesses.
#
# The detected Cargo workspace is bound writable because rust-analyzer and cargo
# may need to write target files and other workspace-local state. If no Cargo
# workspace is detected, the current directory is bound read-only so
# rust-analyzer can still start with its usual no-workspace behavior without
# giving write access to an arbitrary launch directory.

set -euo pipefail

# Hardcode name because this script might be used as ‘rust-analyzer’, and error
# messages would become too confusing.
progname=skn-rust-analyzer

resolve_executable_path() {
    local label=$1
    local path=$2
    local resolved

    if [[ ! -x $path ]]; then
        echo "$progname: $label is not executable: $path" >&2
        exit 2
    fi

    resolved=$(realpath -s -e -- "$path") || {
        echo "$progname: cannot resolve $label: $path" >&2
        exit 2
    }

    printf '%s\n' "$resolved"
}

path_is_skn_cargo_wrapper() {
    local path=$1
    local self self_dir found_skn_cargo

    self=$(realpath -e -- "${BASH_SOURCE[0]}") || return 1
    self_dir=$(dirname -- "$self")

    if [[ -e $self_dir/skn-cargo && $path -ef $self_dir/skn-cargo ]]; then
        return 0
    fi

    if found_skn_cargo=$(type -P skn-cargo 2>/dev/null) && [[ $path -ef $found_skn_cargo ]]; then
        return 0
    fi

    return 1
}

resolve_real_rust_analyzer() {
    local self found resolved

    self=$(realpath -e -- "${BASH_SOURCE[0]}") || {
        echo "$progname: cannot resolve wrapper path" >&2
        exit 2
    }

    if [[ -n ${SKN_REAL_RUST_ANALYZER:-} ]]; then
        if [[ $SKN_REAL_RUST_ANALYZER != /* ]]; then
            echo "$progname: SKN_REAL_RUST_ANALYZER must be an absolute path" >&2
            exit 2
        fi
        resolved=$(resolve_executable_path SKN_REAL_RUST_ANALYZER "$SKN_REAL_RUST_ANALYZER")
        if [[ $resolved -ef $self ]]; then
            echo "$progname: SKN_REAL_RUST_ANALYZER points to this wrapper" >&2
            exit 2
        fi
        printf '%s\n' "$resolved"
        return 0
    fi

    if ! found=$(type -P rust-analyzer 2>/dev/null); then
        echo "$progname: rust-analyzer not found in PATH; set SKN_REAL_RUST_ANALYZER" >&2
        exit 2
    fi

    if [[ $found -ef $self ]]; then
        echo "$progname: rust-analyzer resolves to this wrapper; set SKN_REAL_RUST_ANALYZER to the real rust-analyzer" >&2
        exit 2
    fi

    resolve_executable_path rust-analyzer "$found"
}

resolve_real_cargo() {
    local self found resolved

    self=$(realpath -e -- "${BASH_SOURCE[0]}") || {
        echo "$progname: cannot resolve wrapper path" >&2
        exit 2
    }

    if [[ -n ${SKN_REAL_CARGO:-} ]]; then
        if [[ $SKN_REAL_CARGO != /* ]]; then
            echo "$progname: SKN_REAL_CARGO must be an absolute path" >&2
            exit 2
        fi
        resolved=$(resolve_executable_path SKN_REAL_CARGO "$SKN_REAL_CARGO")
        if [[ $resolved -ef $self ]]; then
            echo "$progname: SKN_REAL_CARGO points to this wrapper" >&2
            exit 2
        fi
        if path_is_skn_cargo_wrapper "$resolved"; then
            echo "$progname: SKN_REAL_CARGO points to skn-cargo" >&2
            exit 2
        fi
        printf '%s\n' "$resolved"
        return 0
    fi

    if ! found=$(type -P cargo 2>/dev/null); then
        echo "$progname: cargo not found in PATH; set SKN_REAL_CARGO" >&2
        exit 2
    fi

    if [[ $found -ef $self ]]; then
        echo "$progname: cargo resolves to this wrapper; set SKN_REAL_CARGO to the real cargo" >&2
        exit 2
    fi

    if path_is_skn_cargo_wrapper "$found"; then
        echo "$progname: cargo resolves to skn-cargo; set SKN_REAL_CARGO to the real cargo" >&2
        exit 2
    fi

    resolve_executable_path cargo "$found"
}

# Parses skn’s +I info header block. This delegates option parsing to skn
# itself instead of mirroring skn’s option grammar here.
network_enabled_from_skn_info() {
    local line state=

    while IFS= read -r line; do
        [[ $line == skn:\ * ]] || break
        case $line in
            "skn: network "*) state=${line#"skn: network "}; break ;;
        esac
    done

    case $state in
        enabled) return 0 ;;
        disabled) return 1 ;;
        *) return 2 ;;
    esac
}

real_rust_analyzer=$(resolve_real_rust_analyzer)
real_cargo=$(resolve_real_cargo)
real_cargo_dir=$(dirname -- "$real_cargo")
sandbox_path=$real_cargo_dir${PATH:+:$PATH}

skn_args=(
    skn
    "$real_rust_analyzer"
    +P
    +E "CARGO=$real_cargo"
    +E "PATH=$sandbox_path"
)

if workspace_manifest=$("$real_cargo" locate-project --workspace --message-format=plain 2>/dev/null); then
    skn_args+=(+W "$(dirname -- "$workspace_manifest")")
else
    skn_args+=(+R "$(pwd)")
fi

# If they exist, make cargo home writable and rustup home readable.
cargo_home=${CARGO_HOME:-${HOME:+$HOME/.cargo}}
[[ -n $cargo_home && -e $cargo_home ]] && skn_args+=(+W "$cargo_home")

rustup_home=${RUSTUP_HOME:-${HOME:+$HOME/.rustup}}
[[ -n $rustup_home && -e $rustup_home ]] && skn_args+=(+R "$rustup_home")

skn_info_output=$("${skn_args[@]}" +I "$@") || exit $?

if network_enabled_from_skn_info <<<"$skn_info_output"; then
    echo "$progname: refusing +N: rust-analyzer can execute project code via Cargo subprocesses" >&2
    echo "$progname: fetch dependencies separately, for example with skn-cargo +N fetch, then run rust-analyzer offline" >&2
    exit 2
else
    case $? in
        1) skn_args+=(+E CARGO_NET_OFFLINE=true) ;;
        *) echo "$progname: internal error parsing skn +I output" >&2; exit 2 ;;
    esac
fi

exec "${skn_args[@]}" "$@"
