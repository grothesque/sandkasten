#!/bin/bash
#
# Run cargo under skn with defaults suitable for building untrusted projects.
#
# This wrapper intentionally stays small and mostly lets skn parse its own
# options.  Leading skn + options may be given before cargo arguments, e.g.:
#
#   skn-cargo +N fetch
#   skn-cargo +W ../dep build
#   skn-cargo +T ~/.cargo build
#
# Without +N, the wrapper asks skn to set CARGO_NET_OFFLINE=true inside the
# sandbox.  This preserves the important separation between fetching
# dependencies with network access and building without it:
#
#   skn-cargo +N fetch
#   skn-cargo build
#
# Cargo arguments are otherwise passed through unchanged, so syntax such as
# +toolchain remains Cargo’s concern.  The only overlap is with leading values
# that match skn’s own + option syntax: for example, +Wsomething is parsed as a
# writable bind, not as a custom Cargo toolchain.  Pass such values after -- if
# needed.
#
# For convenience, define aliases or shell functions, for example:
#
#   alias cargo=skn-cargo
#   alias cargo-fetch='skn-cargo +N fetch'
#   alias cargo-update='skn-cargo +N update'

set -eu

append_path_var() {
    local var_name=$1
    local path=$2
    local value

    [[ -n $path && -e $path ]] || return 0

    value=${!var_name:-}
    case ":$value:" in
        *:"$path":*) ;;
        *) printf -v "$var_name" '%s' "${value:+$value:}$path" ;;
    esac
}

append_default_home_path_var() {
    local var_name=$1
    local override_var_name=$2
    local default_basename=$3
    local path=

    if [[ -n ${!override_var_name:-} ]]; then
        path=${!override_var_name}
    elif [[ -n ${HOME:-} ]]; then
        path=$HOME/$default_basename
    fi

    append_path_var "$var_name" "$path"
}

# Parses skn’s initial +S header block. This delegates option parsing to skn
# itself instead of mirroring skn’s option grammar here.
network_enabled_from_skn_show() {
    local line state=

    while IFS= read -r line; do
        [[ $line == skn:\ * ]] || break
        case $line in
            "skn: network "*) state=${line#"skn: network "}; break ;;
        esac
    done

    case $state in
        enabled) return 0 ;;
        disabled) return 1 ;;
        *) return 2 ;;
    esac
}

# If they exist, make cargo home writable and rustup home readable.
append_default_home_path_var SKN_BINDS CARGO_HOME .cargo
append_default_home_path_var SKN_RO_BINDS RUSTUP_HOME .rustup
export SKN_BINDS SKN_RO_BINDS

skn_args=(
    skn
    cargo
    +P
)

if proj=$(cargo locate-project --workspace --message-format=plain 2>/dev/null); then
    proj=$(dirname -- "$proj")
    skn_args+=( +W "$proj" )
fi

skn_show_status=0
skn_show_output=$("${skn_args[@]}" +S "$@") || skn_show_status=$?
if ((skn_show_status != 0)); then
    exit "$skn_show_status"
fi

if network_enabled_from_skn_show <<<"$skn_show_output"; then
    :
else
    case $? in
        1) skn_args+=(+E CARGO_NET_OFFLINE=true) ;;
        *) echo "${0##*/}: internal error parsing skn +S output" >&2; exit 2 ;;
    esac
fi

exec "${skn_args[@]}" "$@"
