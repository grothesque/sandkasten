#!/bin/bash
#
# Run cargo under skn with defaults suitable for building untrusted projects.
#
# This wrapper intentionally stays small and mostly lets skn parse its own
# options.  Leading skn + options may be given before cargo arguments, e.g.:
#
#   skn-cargo +N fetch
#   skn-cargo +W ../dep build
#   skn-cargo +T ~/.cargo build
#
# Without +N, the wrapper asks skn to set CARGO_NET_OFFLINE=true inside the
# sandbox.  This preserves the important separation between fetching
# dependencies with network access and building without it:
#
#   skn-cargo +N fetch
#   skn-cargo build
#
# With +N, only Cargo subcommands that are expected not to execute project code
# are allowed: fetch, update, add, upgrade, generate-lockfile, and search.
#
# Cargo arguments are otherwise passed through unchanged, so syntax such as
# +toolchain remains Cargo’s concern.  The only overlap is with leading values
# that match skn’s current or reserved + option syntax: for example,
# +Wsomething is parsed as a writable bind, and +Xsomething is rejected as a
# reserved skn option.  Pass such values after -- if needed.
#
# For convenience, define aliases or shell functions, for example:
#
#   alias cargo=skn-cargo
#   alias cargo-fetch='skn-cargo +N fetch'
#   alias cargo-update='skn-cargo +N update'

set -euo pipefail

# Hardcode name because this script might be used as ‘cargo’, and error messages
# would become too confusing.
progname=skn-cargo

if [[ ${SKN_CARGO_WRAPPER_ACTIVE:-} == 1 ]]; then
    echo "$progname: recursive Cargo wrapper invocation; set SKN_REAL_CARGO to the real Cargo command" >&2
    exit 2
fi
export SKN_CARGO_WRAPPER_ACTIVE=1

locate_workspace_manifest() {
    local locate_stderr status

    locate_stderr=$(mktemp) || exit 2

    if workspace_manifest=$("$real_cargo" locate-project --workspace --message-format=plain 2>"$locate_stderr"); then
        rm -f -- "$locate_stderr"
        return 0
    else
        status=$?
    fi

    if grep -F 'recursive Cargo wrapper invocation' "$locate_stderr" >/dev/null; then
        cat "$locate_stderr" >&2
        rm -f -- "$locate_stderr"
        exit "$status"
    fi

    rm -f -- "$locate_stderr"
    return 1
}

# Parses skn’s +I info header block. This delegates option parsing to skn
# itself instead of mirroring skn’s option grammar here.
parse_skn_info() {
    local line command_words=
    local -a skn_command_argv=()

    skn_network_state=
    cargo_argv=()

    while IFS= read -r line; do
        [[ $line == skn:\ * ]] || break
        case $line in
            "skn: sandboxed command: "*) command_words=${line#"skn: sandboxed command: "} ;;
            "skn: network "*) skn_network_state=${line#"skn: network "} ;;
        esac
    done

    [[ -n $command_words ]] || return 1
    case $skn_network_state in
        enabled|disabled) ;;
        *) return 1 ;;
    esac

    eval "skn_command_argv=($command_words)" || return 1
    ((${#skn_command_argv[@]} > 0)) || return 1
    cargo_argv=("${skn_command_argv[@]:1}")
}

cargo_subcommand_for_policy() {
    # Cargo accepts an optional leading rustup-style +toolchain argument.
    if (($#)) && [[ $1 == +* ]]; then
        shift
    fi

    while (($#)); do
        case $1 in
            --) return 0 ;;
            -Zscript*) return 1 ;;
            -Z)
                (($# >= 2)) || return 1
                [[ $2 == script* ]] && return 1
                shift 2
                ;;
            -V|--version|--list|--locked|--offline|--frozen|-h|--help|-q|--quiet|--verbose|-v|-vv|-vvv|-vvvv|-vvvvv)
                shift
                ;;
            --color=*|--config=*|--explain=*|-Z?*)
                shift
                ;;
            --color|--config|--explain|-C)
                (($# >= 2)) || return 1
                shift 2
                ;;
            -*) return 1 ;;
            *) printf '%s\n' "$1"; return 0 ;;
        esac
    done

    return 0
}

cargo_network_subcommand_allowed() {
    local subcommand=$1

    case $subcommand in
        fetch|update|add|upgrade|generate-lockfile|search) return 0 ;;
        *) return 1 ;;
    esac
}

real_cargo=${SKN_REAL_CARGO:-cargo}

skn_args=(
    skn
    "$real_cargo"
    +E
)

if [[ -n ${SKN_REAL_CARGO:-} ]]; then
    skn_args+=(+V "CARGO=$real_cargo")
fi

if locate_workspace_manifest; then
    skn_args+=(+W "$(dirname -- "$workspace_manifest")")
fi

# If they exist, make cargo home writable and rustup home readable.
cargo_home=${CARGO_HOME:-${HOME:+$HOME/.cargo}}
[[ -n $cargo_home && -e $cargo_home ]] && skn_args+=(+W "$cargo_home")

rustup_home=${RUSTUP_HOME:-${HOME:+$HOME/.rustup}}
[[ -n $rustup_home && -e $rustup_home ]] && skn_args+=(+R "$rustup_home")

skn_info_output=$("${skn_args[@]}" +I "$@") || exit $?

if ! parse_skn_info <<<"$skn_info_output"; then
    echo "$progname: internal error parsing skn +I output" >&2
    exit 2
fi

if [[ $skn_network_state == enabled ]]; then
    if ! subcommand=$(cargo_subcommand_for_policy "${cargo_argv[@]}"); then
        echo "$progname: refusing +N: cannot safely identify Cargo subcommand" >&2
        echo "$progname: network-enabled skn-cargo is limited to: fetch, update, add, upgrade, generate-lockfile, search" >&2
        exit 2
    fi

    if ! cargo_network_subcommand_allowed "$subcommand"; then
        if [[ -n $subcommand ]]; then
            echo "$progname: refusing +N with cargo subcommand '$subcommand'" >&2
        else
            echo "$progname: refusing +N without an allowed Cargo subcommand" >&2
        fi
        echo "$progname: network-enabled skn-cargo is limited to: fetch, update, add, upgrade, generate-lockfile, search" >&2
        echo "$progname: fetch dependencies with +N, then build, test, or run offline" >&2
        exit 2
    fi
else
    skn_args+=(+V CARGO_NET_OFFLINE=true)
fi

exec "${skn_args[@]}" "$@"
