#!/bin/bash
#
# Run cargo under skn with defaults suitable for building untrusted projects.
#
# This wrapper intentionally stays small and delegates skn option parsing to
# skn itself. Commands in net_auto_subcommands get network automatically.
# Commands in net_deny_subcommands are never allowed network access.
# Other identifiable subcommands run offline by default, but may use explicit +N.
#
# Examples:
#   skn-cargo fetch
#   skn-cargo +W ../dep build
#   skn-cargo +T ~/.cargo build

set -euo pipefail

# Hardcode name because this script might be used as ‘cargo’, and error messages
# would become too confusing.
progname=skn-cargo

# Space-padded lists.
# Auto-enable network only for commands expected to need it without building or
# executing project code. Refuse network for commands that can build or execute
# code, even when requested explicitly.
net_auto_subcommands=' add fetch generate-lockfile info metadata search tree update vendor '
net_deny_subcommands=' b bench build c check clippy d doc fix install miri package publish r run rustc rustdoc t test '

cargo_wrapper_max_depth=${SKN_CARGO_WRAPPER_MAX_DEPTH:-5}
cargo_wrapper_depth=${SKN_CARGO_WRAPPER_DEPTH:-0}

if [[ ! $cargo_wrapper_max_depth =~ ^[1-9][0-9]*$ ]]; then
    echo "$progname: invalid SKN_CARGO_WRAPPER_MAX_DEPTH: $cargo_wrapper_max_depth" >&2
    exit 2
fi

if [[ ! $cargo_wrapper_depth =~ ^[0-9]+$ ]]; then
    echo "$progname: invalid SKN_CARGO_WRAPPER_DEPTH: $cargo_wrapper_depth" >&2
    exit 2
fi

if ((10#$cargo_wrapper_depth >= 10#$cargo_wrapper_max_depth)); then
    echo "$progname: recursive Cargo wrapper invocation depth exceeded" >&2
    exit 2
fi

export SKN_CARGO_WRAPPER_DEPTH=$((10#$cargo_wrapper_depth + 1))

locate_workspace_manifest() {
    local cargo_cwd=$1
    local use_cargo_cwd=$2
    local locate_stderr status

    locate_stderr=$(mktemp) || exit 2

    if workspace_manifest=$({
        if ((use_cargo_cwd)); then
            cd -- "$cargo_cwd" || exit
        fi
        "$real_cargo" locate-project --workspace --message-format=plain
    } 2>"$locate_stderr"); then
        rm -f -- "$locate_stderr"
        return 0
    else
        status=$?
    fi

    if grep -F 'recursive Cargo wrapper invocation' "$locate_stderr" >/dev/null; then
        cat "$locate_stderr" >&2
        rm -f -- "$locate_stderr"
        exit "$status"
    fi

    rm -f -- "$locate_stderr"
    return 1
}

# Parses skn’s +I info header block. This delegates option parsing to skn
# itself instead of mirroring skn’s option grammar here.
parse_skn_info() {
    local line command_words=
    local -a skn_command_argv=()

    skn_network_state=
    cargo_argv=()

    while IFS= read -r line; do
        [[ $line == skn:\ * ]] || break
        case $line in
            "skn: sandboxed command: "*) command_words=${line#"skn: sandboxed command: "} ;;
            "skn: network "*) skn_network_state=${line#"skn: network "} ;;
        esac
    done

    [[ -n $command_words ]] || return 1
    case $skn_network_state in
        enabled|disabled) ;;
        *) return 1 ;;
    esac

    eval "skn_command_argv=($command_words)" || return 1
    ((${#skn_command_argv[@]} > 0)) || return 1
    cargo_argv=("${skn_command_argv[@]:1}")
}

word_in() { [[ $2 == *" $1 "* ]]; }

has_attached_value() {
    local arg=$1 opts=$2 opt
    for opt in $opts; do [[ $arg == "$opt="* ]] && return 0; done
    return 1
}

set_parsed_positional() {
    parsed_arg=$1; parsed_found=1; shift; parsed_tail=("$@")
}

parse_cargo_positionals() {
    local scope=$1 arg
    local flags=' --locked --offline --frozen -q --quiet --verbose -v -vv -vvv -vvvv -vvvvv '
    local value_opts=' --color --config '
    shift; parsed_arg=; parsed_tail=(); parsed_found=0

    case $scope in
        top)
            flags+=' -V --version --list -h --help '
            value_opts+=' --explain '
            ;;
        creation)
            flags+=' --bin --lib '
            value_opts+=' --vcs --edition --name --registry '
            ;;
        *)
            return 1
            ;;
    esac

    while (($#)); do
        arg=$1
        case $arg in
            --)
                shift
                (($#)) && set_parsed_positional "$@"
                return 0
                ;;
            -Zscript*)
                [[ $scope == top ]] && return 1
                ;;
            -C)
                [[ $scope == top ]] || return 1
                (($# >= 2)) || return 1
                cargo_cwd=$2
                cargo_has_cwd=1
                shift 2
                continue
                ;;
            -C?*)
                [[ $scope == top ]] || return 1
                cargo_cwd=${arg:2}
                cargo_has_cwd=1
                shift
                continue
                ;;
            -h|--help)
                [[ $scope == creation ]] && return 1
                ;;
            -Z)
                (($# >= 2)) || return 1
                [[ $scope == top && $2 == script* ]] && return 1
                shift 2
                continue
                ;;
        esac

        if [[ $arg == -Z?* ]] ||
            word_in "$arg" "$flags" ||
            has_attached_value "$arg" "$value_opts"; then
            shift
        elif word_in "$arg" "$value_opts"; then
            (($# >= 2)) || return 1
            shift 2
        elif [[ $arg == -* ]]; then
            return 1
        else
            set_parsed_positional "$@"
            return 0
        fi
    done
}

analyze_cargo_args() {
    cargo_subcommand=
    cargo_subcommand_args=()
    cargo_creation_bind=
    cargo_cwd=
    cargo_has_cwd=0

    # Cargo accepts an optional leading rustup-style +toolchain argument.
    if (($#)) && [[ $1 == +* ]]; then
        shift
    fi

    parse_cargo_positionals top "$@" || return 1
    if ((parsed_found)); then
        cargo_subcommand=$parsed_arg
        cargo_subcommand_args=("${parsed_tail[@]}")
    fi
}

absolute_from_cargo_cwd() {
    local path=$1 base=$PWD

    if [[ $path == /* ]]; then
        realpath -s -m -- "$path"
        return
    elif ((cargo_has_cwd)); then
        [[ $cargo_cwd == /* ]] && base=$cargo_cwd || base=$PWD/$cargo_cwd
    fi

    realpath -s -m -- "$base/$path"
}

find_cargo_creation_bind() {
    local target_path bind_path

    case $cargo_subcommand in
        new|init) ;;
        *) return 1 ;;
    esac

    parse_cargo_positionals creation "${cargo_subcommand_args[@]}" || return 1

    if [[ $cargo_subcommand == new ]]; then
        ((parsed_found)) || return 1
        target_path=$(absolute_from_cargo_cwd "$parsed_arg") || return 1
        bind_path=$(dirname -- "$target_path") || return 1
    else
        if ((parsed_found)); then
            target_path=$(absolute_from_cargo_cwd "$parsed_arg") || return 1
        else
            target_path=$(absolute_from_cargo_cwd .) || return 1
        fi

        [[ -d $target_path ]] && bind_path=$target_path || bind_path=$(dirname -- "$target_path") || return 1
    fi

    [[ $bind_path != / ]] || return 1
    cargo_creation_bind=$bind_path
}

cargo_install_likely_needs_network() {
    local arg likely=0

    for arg; do
        case $arg in
            -h|--help|--list|--offline|--frozen|--path|--path=*) return 1 ;;
            --git=*|--index=*|--registry=*) likely=1 ;;
            --*) ;;
            -*) ;;
            *) likely=1 ;;
        esac
    done

    ((likely))
}

real_cargo=${SKN_REAL_CARGO:-cargo}

skn_args=(
    skn
    "$real_cargo"
    +E
)

if [[ -n ${SKN_REAL_CARGO:-} ]]; then
    skn_args+=(+V "CARGO=$real_cargo")
fi

skn_info_output=$("${skn_args[@]}" +I "$@") || exit $?

if ! parse_skn_info <<<"$skn_info_output"; then
    echo "$progname: internal error parsing skn +I output" >&2
    exit 2
fi

if analyze_cargo_args "${cargo_argv[@]}"; then
    if [[ $cargo_subcommand == install ]]; then
        if [[ $skn_network_state == enabled ]] ||
            cargo_install_likely_needs_network "${cargo_subcommand_args[@]}"; then
            echo "$progname: cargo install downloads and builds in one step" >&2
            echo "$progname: run real Cargo in a networked skn shell instead" >&2
            exit 2
        fi
    fi

    if [[ $net_auto_subcommands == *" $cargo_subcommand "* ]]; then
        [[ $skn_network_state == disabled ]] && skn_args+=(+N)
    elif [[ -z $cargo_subcommand || $net_deny_subcommands == *" $cargo_subcommand "* ]]; then
        if [[ $skn_network_state == enabled ]]; then
            echo "$progname: refusing +N: network is not allowed for this Cargo invocation" >&2
            exit 2
        fi
        skn_args+=(+V CARGO_NET_OFFLINE=true)
    elif [[ $skn_network_state == disabled ]]; then
        skn_args+=(+V CARGO_NET_OFFLINE=true)
    fi
elif [[ $skn_network_state == enabled ]]; then
    echo "$progname: refusing +N: cannot safely identify Cargo subcommand" >&2
    exit 2
else
    skn_args+=(+V CARGO_NET_OFFLINE=true)
fi

if find_cargo_creation_bind; then
    skn_args+=(+W "$cargo_creation_bind")
fi

if locate_workspace_manifest "$cargo_cwd" "$cargo_has_cwd"; then
    skn_args+=(+W "$(dirname -- "$workspace_manifest")")
fi

# If they exist, make cargo home writable and rustup home readable.
cargo_home=${CARGO_HOME:-${HOME:+$HOME/.cargo}}
[[ -n $cargo_home && -e $cargo_home ]] && skn_args+=(+W "$cargo_home")

rustup_home=${RUSTUP_HOME:-${HOME:+$HOME/.rustup}}
[[ -n $rustup_home && -e $rustup_home ]] && skn_args+=(+R "$rustup_home")

exec "${skn_args[@]}" "$@"
