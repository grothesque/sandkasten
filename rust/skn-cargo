#!/bin/bash
#
# Run cargo under skn with defaults suitable for building untrusted projects.
#
# This wrapper intentionally stays small and delegates skn option parsing to
# skn itself. It tries to preserve ordinary Cargo workflows while separating
# dependency fetching from build-time code execution where possible.
#
# Examples:
#   skn-cargo fetch
#   skn-cargo +W ../dep build
#   skn-cargo +T ~/.cargo build

set -euo pipefail

# Hardcode name because this script might be used as ‘cargo’, and error messages
# would become too confusing.
progname=skn-cargo

error() {
    echo "$progname: $*" >&2
    exit 2
}

# Space-padded subcommand policy lists.
# Subcommands in net_auto_subcommands get network automatically because they are
# expected to need it without building or executing project code. Subcommands in
# auto_prefetch_subcommands are split into a networked `cargo fetch` followed by
# the requested command offline. Other identifiable subcommands run offline by
# default, unless explicit +N opts into a single networked invocation.
net_auto_subcommands=' add fetch generate-lockfile info metadata search tree update vendor '
auto_prefetch_subcommands=' b bench build c check clippy d doc r run t test '

cargo_wrapper_max_depth=${SKN_CARGO_WRAPPER_MAX_DEPTH:-5}
cargo_wrapper_depth=${SKN_CARGO_WRAPPER_DEPTH:-0}

[[ $cargo_wrapper_max_depth =~ ^[1-9][0-9]*$ ]] ||
    error "invalid SKN_CARGO_WRAPPER_MAX_DEPTH: $cargo_wrapper_max_depth"

[[ $cargo_wrapper_depth =~ ^[0-9]+$ ]] ||
    error "invalid SKN_CARGO_WRAPPER_DEPTH: $cargo_wrapper_depth"

((10#$cargo_wrapper_depth < 10#$cargo_wrapper_max_depth)) ||
    error "recursive Cargo wrapper invocation depth exceeded"

export SKN_CARGO_WRAPPER_DEPTH=$((10#$cargo_wrapper_depth + 1))

# Parses skn’s +0 machine-readable info. This delegates option parsing to skn
# itself instead of mirroring skn’s option grammar here.
parse_skn_info() {
    local argc arg delimiter_seen=0 format header_done=0 i line
    local -a parsed_argv=()

    skn_argv=()
    cargo_argv=()
    explicit_network=0

    while IFS= read -r line; do
        [[ -n $line ]] || { header_done=1; break; }

        case $line in
            "format: "*) format=${line#"format: "} ;;
            "argc: "*) argc=${line#"argc: "} ;;
            *": "*) ;;
            *) return 1 ;;
        esac
    done

    ((header_done)) || return 1
    [[ ${format:-} == skn-info-mk2 ]] || return 1
    [[ ${argc:-} =~ ^[0-9]+$ ]] || return 1
    ((10#$argc >= 2)) || return 1

    for ((i = 0; i < 10#$argc; ++i)); do
        IFS= read -r -d '' arg || return 1
        parsed_argv+=("$arg")
    done

    for ((i = 1; i < 10#$argc; ++i)); do
        arg=${parsed_argv[i]}
        if [[ $arg == ++ ]]; then
            delimiter_seen=1
            cargo_argv=("${parsed_argv[@]:i + 1}")
            break
        fi

        skn_argv+=("$arg")
        [[ $arg == +N ]] && explicit_network=1
    done

    ((delimiter_seen)) || return 1
}

word_in() { [[ $2 == *" $1 "* ]]; }

has_attached_value() {
    local arg=$1 opts=$2 opt
    for opt in $opts; do [[ $arg == "$opt="* ]] && return 0; done
    return 1
}

set_parsed_positional() {
    parsed_arg=$1; parsed_found=1; shift; parsed_tail=("$@")
}

record_cargo_lock_intent() {
    case $1 in
        --offline)
            # Cargo may still create/update Cargo.lock using cached data.
            cargo_cli_offline_intent=1
            ;;
        --locked)
            # Cargo must not create/update Cargo.lock.
            cargo_cli_locked_intent=1
            ;;
        --frozen)
            # Both offline and locked
            cargo_cli_offline_intent=1
            cargo_cli_locked_intent=1
            ;;
        *) return 1 ;;
    esac
}

record_cargo_fetch_top_opt() {
    local arg=$1

    case $arg in
        -C|--config|--color|-Z)
            (($# >= 2)) || return 1
            cargo_fetch_prefix+=("$arg" "$2")
            ;;
        -C?*|-Z?*|--config=*|--color=*|--locked|-q|--quiet|--verbose|-v|-vv|-vvv|-vvvv|-vvvvv)
            cargo_fetch_prefix+=("$arg")
            ;;
        *)
            cargo_fetch_prefix_valid=0
            ;;
    esac

    return 0
}

parse_cargo_positionals() {
    local scope=$1 arg
    local flags=' --locked --offline --frozen -q --quiet --verbose -v -vv -vvv -vvvv -vvvvv '
    local value_opts=' --color --config '
    shift; parsed_arg=; parsed_tail=(); parsed_found=0

    case $scope in
        top)
            flags+=' -V --version --list -h --help '
            value_opts+=' --explain '
            ;;
        creation)
            flags+=' --bin --lib '
            value_opts+=' --vcs --edition --name --registry '
            ;;
        *)
            return 1
            ;;
    esac

    while (($#)); do
        arg=$1
        case $arg in
            --)
                shift
                (($#)) && set_parsed_positional "$@"
                return 0
                ;;
            -Zscript*)
                [[ $scope == top ]] && return 1
                ;;
            -C)
                [[ $scope == top ]] || return 1
                (($# >= 2)) || return 1
                cargo_cwd=$2
                cargo_has_cwd=1
                record_cargo_fetch_top_opt "$arg" "$2"
                shift 2
                continue
                ;;
            -C?*)
                [[ $scope == top ]] || return 1
                cargo_cwd=${arg:2}
                cargo_has_cwd=1
                record_cargo_fetch_top_opt "$arg"
                shift
                continue
                ;;
            -h|--help)
                [[ $scope == creation ]] && return 1
                ;;
            -Z)
                (($# >= 2)) || return 1
                [[ $scope == top && $2 == script* ]] && return 1
                [[ $scope == top ]] && record_cargo_fetch_top_opt "$arg" "$2"
                shift 2
                continue
                ;;
        esac

        # Track top-level Cargo offline intent while parsing options. Later
        # split-invocation logic must not prefetch when Cargo was asked to be
        # offline.
        if [[ $scope == top ]]; then
            record_cargo_lock_intent "$arg" || :
        fi

        if [[ $arg == -Z?* ]] ||
            word_in "$arg" "$flags" ||
            has_attached_value "$arg" "$value_opts"; then
            [[ $scope == top ]] && record_cargo_fetch_top_opt "$arg"
            shift
        elif word_in "$arg" "$value_opts"; then
            (($# >= 2)) || return 1
            [[ $scope == top ]] && record_cargo_fetch_top_opt "$arg" "$2"
            shift 2
        elif [[ $arg == -* ]]; then
            return 1
        else
            set_parsed_positional "$@"
            return 0
        fi
    done
}

analyze_cargo_args() {
    local arg

    cargo_subcommand=
    cargo_subcommand_args=()
    cargo_creation_bind=
    cargo_cwd=
    cargo_has_cwd=0
    cargo_cli_offline_intent=0
    cargo_cli_locked_intent=0
    cargo_fetch_prefix=()
    # Some understood top-level Cargo options, such as --help or --version, do
    # not make sense on a synthetic `cargo fetch` invocation. Keep parsing them
    # for Cargo compatibility, but suppress auto-prefetch when they appear.
    cargo_fetch_prefix_valid=1

    # Cargo accepts an optional leading rustup-style +toolchain argument.
    if (($#)) && [[ $1 == +* ]]; then
        cargo_fetch_prefix+=("$1")
        shift
    fi

    parse_cargo_positionals top "$@" || return 1
    if ((parsed_found)); then
        cargo_subcommand=$parsed_arg
        cargo_subcommand_args=("${parsed_tail[@]}")

        for arg in "${cargo_subcommand_args[@]}"; do
            [[ $arg == -- ]] && break
            record_cargo_lock_intent "$arg" || :
        done
    fi

    return 0
}

absolute_from_cargo_cwd() {
    local path=$1 base=$PWD

    if [[ $path == /* ]]; then
        realpath -s -m -- "$path"
        return
    elif ((cargo_has_cwd)); then
        [[ $cargo_cwd == /* ]] && base=$cargo_cwd || base=$PWD/$cargo_cwd
    fi

    realpath -s -m -- "$base/$path"
}

find_cargo_creation_bind() {
    local target_path bind_path

    case $cargo_subcommand in
        new|init) ;;
        *) return 1 ;;
    esac

    parse_cargo_positionals creation "${cargo_subcommand_args[@]}" || return 1

    if [[ $cargo_subcommand == new ]]; then
        ((parsed_found)) || return 1
        target_path=$(absolute_from_cargo_cwd "$parsed_arg") || return 1
        bind_path=$(dirname -- "$target_path") || return 1
    else
        if ((parsed_found)); then
            target_path=$(absolute_from_cargo_cwd "$parsed_arg") || return 1
        else
            target_path=$(absolute_from_cargo_cwd .) || return 1
        fi

        [[ -d $target_path ]] && bind_path=$target_path || bind_path=$(dirname -- "$target_path") || return 1
    fi

    [[ $bind_path != / ]] || return 1
    cargo_creation_bind=$bind_path
}

cargo_subcommand_args_have_help_intent() {
    local arg

    for arg; do
        case $arg in
            --) return 1 ;;
            -h|--help) return 0 ;;
        esac
    done

    return 1
}

cargo_has_offline_intent() {
    ((cargo_cli_offline_intent)) || [[ ${CARGO_NET_OFFLINE:-} == true ]]
}

cargo_lockfile_update_forbidden() {
    ((cargo_cli_locked_intent))
}

cargo_context_needs_lockfile_grant() {
    cargo_lockfile_update_forbidden && return 1
    ((cargo_fetch_prefix_valid)) || return 1
    [[ -n $cargo_subcommand ]] || return 1
    cargo_subcommand_args_have_help_intent "${cargo_subcommand_args[@]}" && return 1

    return 0
}

reject_skn_cargo_net_offline_env() {
    echo "$progname: do not pass CARGO_NET_OFFLINE through skn +V" >&2
    echo "$progname: use --offline/--frozen, or set CARGO_NET_OFFLINE before invoking $progname" >&2
    exit 2
}

reject_ambiguous_skn_env_options() {
    local skn_arg

    for skn_arg in "${skn_argv[@]}"; do
        case $skn_arg in
            +VCARGO_NET_OFFLINE|+VCARGO_NET_OFFLINE=*) reject_skn_cargo_net_offline_env ;;
        esac
    done

    return 0
}

init_skn_args() {
    skn_args=(
        skn
        "$real_cargo"
        +E
    )

    if [[ -n ${SKN_REAL_CARGO:-} ]]; then
        skn_args+=(+V "CARGO=$real_cargo")
    fi
}

parse_wrapper_args() {
    parse_skn_info < <("${skn_args[@]}" +0 "$@") ||
        error "internal error parsing skn +0 output"

    reject_ambiguous_skn_env_options
}

apply_network_policy() {
    if analyze_cargo_args "${cargo_argv[@]}"; then
        if word_in "$cargo_subcommand" "$net_auto_subcommands"; then
            if ((! explicit_network)) && ! cargo_has_offline_intent; then
                skn_args+=(+N)
            fi
        elif ((! explicit_network)); then
            skn_args+=(+V CARGO_NET_OFFLINE=true)
        fi
    elif ((explicit_network)); then
        error "refusing +N: cannot safely identify Cargo subcommand"
    else
        skn_args+=(+V CARGO_NET_OFFLINE=true)
    fi

    return 0
}

collect_cargo_context_args() {
    local cargo_effective_cwd output
    local -a expansion_profile_args=()

    cargo_effective_cwd=$(absolute_from_cargo_cwd .) ||
        error "could not determine Cargo working directory"

    if ! cargo_context_needs_lockfile_grant; then
        expansion_profile_args=(no-lockfile)
    fi

    if output=$(cd -- "$cargo_effective_cwd" && skn-expansion-cargo "${expansion_profile_args[@]}"); then
        cargo_context_args=()
        [[ -z $output ]] || mapfile -t cargo_context_args <<<"$output"
    else
        exit $?
    fi

    if find_cargo_creation_bind; then
        cargo_context_args+=(+W "$cargo_creation_bind")
    fi
}

run_cargo_once() {
    exec "${skn_args[@]}" "$@"
}

construct_prefetch_argv() {
    local arg

    # Top-level Cargo options were parsed and copied while identifying the
    # subcommand. Here, only copy subcommand options accepted by `cargo fetch`
    # and ignore other command-specific arguments so they remain exclusive to
    # the real Cargo invocation.
    cargo_fetch_argv=("${cargo_fetch_prefix[@]}" fetch)

    set -- "${cargo_subcommand_args[@]}"

    while (($#)); do
        arg=$1
        case $arg in
            --)
                break
                ;;
            --config|--color|--manifest-path|--target)
                (($# >= 2)) || return 1
                cargo_fetch_argv+=("$arg" "$2")
                shift 2
                ;;
            --config=*|--color=*|--manifest-path=*|--target=*|--locked|-q|--quiet|--verbose|-v|-vv|-vvv|-vvvv|-vvvvv)
                cargo_fetch_argv+=("$arg")
                shift
                ;;
            *)
                shift
                ;;
        esac
    done
}

auto_prefetch_cargo_command() {
    word_in "$cargo_subcommand" "$auto_prefetch_subcommands" || return 1
    ((cargo_fetch_prefix_valid)) || return 1
    ((explicit_network)) && return 1
    cargo_has_offline_intent && return 1
    cargo_subcommand_args_have_help_intent "${cargo_subcommand_args[@]}" && return 1
    return 0
}

run_cargo_with_prefetch() {
    local -a fetch_skn_args

    construct_prefetch_argv ||
        error "internal error constructing cargo fetch invocation"

    fetch_skn_args=(
        skn
        "$real_cargo"
        "${skn_argv[@]}"
        +N
        "${cargo_context_args[@]}"
    )

    "${fetch_skn_args[@]}" ++ "${cargo_fetch_argv[@]}"
    run_cargo_once "$@"
}

real_cargo=${SKN_REAL_CARGO:-cargo}

init_skn_args
parse_wrapper_args "$@"
apply_network_policy
collect_cargo_context_args
skn_args+=("${cargo_context_args[@]}")
if auto_prefetch_cargo_command; then
    run_cargo_with_prefetch "$@"
else
    run_cargo_once "$@"
fi
