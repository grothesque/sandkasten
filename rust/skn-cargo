#!/bin/bash
#
# Run cargo under skn with defaults suitable for building untrusted projects.
#
# This wrapper intentionally stays small and delegates skn option parsing to
# skn itself. Commands in network_cargo_subcommands get network automatically;
# other Cargo invocations run offline, and explicit +N is refused for them.
#
# Examples:
#   skn-cargo fetch
#   skn-cargo +W ../dep build
#   skn-cargo +T ~/.cargo build

set -euo pipefail

# Hardcode name because this script might be used as ‘cargo’, and error messages
# would become too confusing.
progname=skn-cargo

# Space-padded list. Do not add commands that can execute project code, such as
# build, check, test, run, doc, install, or most custom commands.
network_cargo_subcommands=' fetch update add generate-lockfile search '

if [[ ${SKN_CARGO_WRAPPER_ACTIVE:-} == 1 ]]; then
    echo "$progname: recursive Cargo wrapper invocation; set SKN_REAL_CARGO to the real Cargo command" >&2
    exit 2
fi
export SKN_CARGO_WRAPPER_ACTIVE=1

locate_workspace_manifest() {
    local cargo_cwd=$1
    local use_cargo_cwd=$2
    local locate_stderr status

    locate_stderr=$(mktemp) || exit 2

    if workspace_manifest=$({
        if ((use_cargo_cwd)); then
            cd -- "$cargo_cwd" || exit
        fi
        "$real_cargo" locate-project --workspace --message-format=plain
    } 2>"$locate_stderr"); then
        rm -f -- "$locate_stderr"
        return 0
    else
        status=$?
    fi

    if grep -F 'recursive Cargo wrapper invocation' "$locate_stderr" >/dev/null; then
        cat "$locate_stderr" >&2
        rm -f -- "$locate_stderr"
        exit "$status"
    fi

    rm -f -- "$locate_stderr"
    return 1
}

# Parses skn’s +I info header block. This delegates option parsing to skn
# itself instead of mirroring skn’s option grammar here.
parse_skn_info() {
    local line command_words=
    local -a skn_command_argv=()

    skn_network_state=
    cargo_argv=()

    while IFS= read -r line; do
        [[ $line == skn:\ * ]] || break
        case $line in
            "skn: sandboxed command: "*) command_words=${line#"skn: sandboxed command: "} ;;
            "skn: network "*) skn_network_state=${line#"skn: network "} ;;
        esac
    done

    [[ -n $command_words ]] || return 1
    case $skn_network_state in
        enabled|disabled) ;;
        *) return 1 ;;
    esac

    eval "skn_command_argv=($command_words)" || return 1
    ((${#skn_command_argv[@]} > 0)) || return 1
    cargo_argv=("${skn_command_argv[@]:1}")
}

analyze_cargo_args() {
    cargo_subcommand=
    cargo_cwd=
    cargo_has_cwd=0

    # Cargo accepts an optional leading rustup-style +toolchain argument.
    if (($#)) && [[ $1 == +* ]]; then
        shift
    fi

    while (($#)); do
        case $1 in
            --) return 0 ;;
            -Zscript*) return 1 ;;
            -Z)
                (($# >= 2)) || return 1
                [[ $2 == script* ]] && return 1
                shift 2
                ;;
            -C)
                (($# >= 2)) || return 1
                cargo_cwd=$2
                cargo_has_cwd=1
                shift 2
                ;;
            -C?*)
                cargo_cwd=${1:2}
                cargo_has_cwd=1
                shift
                ;;
            -V|--version|--list|--locked|--offline|--frozen|-h|--help|-q|--quiet|--verbose|-v|-vv|-vvv|-vvvv|-vvvvv)
                shift
                ;;
            --color=*|--config=*|--explain=*|-Z?*)
                shift
                ;;
            --color|--config|--explain)
                (($# >= 2)) || return 1
                shift 2
                ;;
            -*) return 1 ;;
            *) cargo_subcommand=$1; return 0 ;;
        esac
    done

    return 0
}

real_cargo=${SKN_REAL_CARGO:-cargo}

skn_args=(
    skn
    "$real_cargo"
    +E
)

if [[ -n ${SKN_REAL_CARGO:-} ]]; then
    skn_args+=(+V "CARGO=$real_cargo")
fi

skn_info_output=$("${skn_args[@]}" +I "$@") || exit $?

if ! parse_skn_info <<<"$skn_info_output"; then
    echo "$progname: internal error parsing skn +I output" >&2
    exit 2
fi

if analyze_cargo_args "${cargo_argv[@]}"; then
    if [[ $network_cargo_subcommands == *" $cargo_subcommand "* ]]; then
        [[ $skn_network_state == disabled ]] && skn_args+=(+N)
    elif [[ $skn_network_state == enabled ]]; then
        echo "$progname: refusing +N: network is not allowed for this Cargo invocation" >&2
        exit 2
    else
        skn_args+=(+V CARGO_NET_OFFLINE=true)
    fi
elif [[ $skn_network_state == enabled ]]; then
    echo "$progname: refusing +N: cannot safely identify Cargo subcommand" >&2
    exit 2
else
    skn_args+=(+V CARGO_NET_OFFLINE=true)
fi

if locate_workspace_manifest "$cargo_cwd" "$cargo_has_cwd"; then
    skn_args+=(+W "$(dirname -- "$workspace_manifest")")
fi

# If they exist, make cargo home writable and rustup home readable.
cargo_home=${CARGO_HOME:-${HOME:+$HOME/.cargo}}
[[ -n $cargo_home && -e $cargo_home ]] && skn_args+=(+W "$cargo_home")

rustup_home=${RUSTUP_HOME:-${HOME:+$HOME/.rustup}}
[[ -n $rustup_home && -e $rustup_home ]] && skn_args+=(+R "$rustup_home")

exec "${skn_args[@]}" "$@"
