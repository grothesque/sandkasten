#!/bin/bash

set -euo pipefail

progname="${0##*/}"

usage() {
    cat <<EOF
Usage: $progname COMMAND [skn-options] [--] [COMMAND-args...]

Run COMMAND inside a bwrap sandbox intended for untrusted code. The sandbox
has a private /tmp, a mostly cleared environment unless +P is used, and no
network access unless enabled with +N.

The skn command line interface is unusual: the command to be sandboxed comes
first, followed by skn's own + options and then the command's arguments. This
keeps aliases and small wrappers transparent while putting skn's controls in a
separate namespace from ordinary command options. For example

alias foo='skn foo'

Now, the foo alias behaves almost like the unwrapped foo command, except that
it runs sandboxed and accepts skn + options before the wrapped command's own
arguments. If the unwrapped foo needs an argument that looks like a skn option,
it can be given after another command argument, or -- can be used.

The only host data bound by default is /usr, optional system runtime paths
such as /bin and /lib, and a few selected parts of /etc, all read-only. DNS
configuration and common public CA root locations are added only with +N.
Other host data is not visible unless explicitly bound into the sandbox with
+R/+W/+T or configured read-only through SKN_RO_BINDS. When not using +S or
+I, paths provided through +R/+W/+T are validated by the mandatory
SKN_PATH_CHECK command.

skn-options:
  +R PATH         bind PATH read-only into the sandbox
  +W PATH         bind PATH writable into the sandbox
  +T PATH         bind directory PATH transient-writable; writes are discarded
  +E VAR=VALUE    set environment VAR to VALUE inside the sandbox
  +A ARG          prepend ARG to COMMAND arguments
  +N              enable network access
  +P              preserve caller environment instead of clearing it
  +S              show the sandbox plan after parsing, then exit
  +I              show only the parsed skn info header, then exit
  --              stop parsing skn options

While skn is parsing options, unrecognized +<uppercase> forms are reserved
for future skn options; use -- before command arguments that look like that.

Environment:
  SKN_PATH_CHECK  mandatory unless +S or +I is used; command used to validate
                  paths from +R/+W/+T; executed directly with the path as its
                  only argument. Set to 'true' to disable.
  SKN_RO_BINDS    colon-separated absolute paths to bind read-only
EOF
}

offer_help_and_exit() {
    echo "Try '$progname --help' for more information." >&2
    exit 2
}

quote_shell_words() {
    local arg quoted out='' sep=''

    for arg in "$@"; do
        printf -v quoted '%q' "$arg"
        out+="$sep$quoted"
        sep=' '
    done

    printf '%s' "$out"
}

print_shell_words() {
    local indent=$1
    local suffix=$2
    shift 2

    printf '%s%s%s\n' "$indent" "$(quote_shell_words "$@")" "$suffix"
}

add_bwrap_args() {
    bwrap_args+=("$@")
    bwrap_display_lines+=("$(quote_shell_words "$@")")
}

add_ro_bind_try() {
    local path=$1

    add_bwrap_args --ro-bind-try "$path" "$path"
}

print_bwrap_command() {
    local continuation line

    printf -v continuation " %b" "\\\\"
    print_shell_words '  ' "$continuation" bwrap

    for line in "${bwrap_display_lines[@]}"; do
        printf '    %s%s\n' "$line" "$continuation"
    done

    print_shell_words '    ' "$continuation" --
    print_shell_words '    ' '' "$@"
}

queue_env() {
    local assignment=$1
    local name value

    if [[ $assignment != *=* ]]; then
        echo "$progname: invalid argument for +E: expected VAR=VALUE" >&2
        offer_help_and_exit
    fi

    name=${assignment%%=*}
    value=${assignment#*=}

    if [[ ! $name =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
        echo "$progname: invalid environment variable name for +E: $name" >&2
        offer_help_and_exit
    fi

    env_queue+=("$name" "$value")
}

add_queued_envs() {
    local i

    for ((i = 0; i < ${#env_queue[@]}; i += 2)); do
        add_bwrap_args --setenv "${env_queue[i]}" "${env_queue[i + 1]}"
    done
}

check_path() {
    local label=$1
    local path=$2

    "$SKN_PATH_CHECK" "$path" || {
        echo "$progname: SKN_PATH_CHECK rejected $path ($label) for sharing with sandbox" >&2
        offer_help_and_exit
    }
}

queue_bind() {
    local option=$1
    local path=$2
    local needs_check=${3:-0}

    if [[ -z $path ]]; then
        echo "$progname: empty path for $option" >&2
        offer_help_and_exit
    fi

    bind_queue+=("$option" "$path" "$needs_check")
}

add_bind() {
    local option=$1
    local path=$2
    local needs_check=$3
    local abs_path realpath_args

    if ((show_mode)); then
        realpath_args=(-s -m)
    else
        if [[ $needs_check == 1 ]]; then
            check_path "$option option" "$path"
        fi
        realpath_args=(-s -e)
    fi

    abs_path=$(realpath "${realpath_args[@]}" -- "$path") || {
        echo "$progname: invalid path for $option: $path" >&2
        offer_help_and_exit
    }

    case $option in
        +R) add_bwrap_args --ro-bind "$abs_path" "$abs_path" ;;
        +W) add_bwrap_args --bind "$abs_path" "$abs_path" ;;
        +T)
            if ((! show_mode)) && [[ ! -d $abs_path ]]; then
                echo "$progname: +T requires an existing directory: $path" >&2
                offer_help_and_exit
            fi
            add_bwrap_args --overlay-src "$abs_path" --tmp-overlay "$abs_path"
            ;;
        *)
            echo "$progname: internal error: invalid bind option: $option" >&2
            exit 2
            ;;
    esac
}

add_queued_binds() {
    local i

    for ((i = 0; i < ${#bind_queue[@]}; i += 3)); do
        add_bind "${bind_queue[i]}" "${bind_queue[i + 1]}" "${bind_queue[i + 2]}"
    done
}

queue_env_ro_bind() {
    local path=$1

    if [[ -z $path ]]; then
        echo "$progname: empty path in SKN_RO_BINDS" >&2
        offer_help_and_exit
    fi

    if [[ $path != /* ]]; then
        echo "$progname: SKN_RO_BINDS entries must be absolute paths: $path" >&2
        offer_help_and_exit
    fi

    queue_bind +R "$path" 0
}

queue_env_ro_binds() {
    local value path

    [[ -v SKN_RO_BINDS ]] || return 0
    value=$SKN_RO_BINDS
    [[ -n $value ]] || return 0

    while [[ $value == *:* ]]; do
        path=${value%%:*}
        queue_env_ro_bind "$path"
        value=${value#*:}
    done

    queue_env_ro_bind "$value"
}

add_base_bwrap_setup() {
    add_bwrap_args --unshare-all
    add_bwrap_args --new-session
    add_bwrap_args --die-with-parent

    # Basic runtime filesystem
    add_bwrap_args --proc /proc
    add_bwrap_args --dev /dev
    add_bwrap_args --tmpfs /tmp
    add_bwrap_args --ro-bind /usr /usr
    add_ro_bind_try /bin
    add_ro_bind_try /sbin
    add_ro_bind_try /lib
    add_ro_bind_try /lib64
    add_ro_bind_try /lib32

    # Optional distro/system integration files. These are deliberately narrow
    # read-only binds; missing paths are ignored by bubblewrap.
    add_ro_bind_try /etc/alternatives
    add_ro_bind_try /etc/manpath.config
    add_ro_bind_try /etc/man_db.conf
    add_ro_bind_try /etc/man.conf
}

add_network_bwrap_setup() {
    add_ro_bind_try /etc/resolv.conf

    # Common public CA root locations, based on Go’s Linux x509 search paths.
    # Bind certificate directories as directories, and bind bundle-file paths
    # that are not covered by those directory binds separately.
    add_ro_bind_try /etc/ssl/certs
    add_ro_bind_try /etc/pki/tls/certs
    add_ro_bind_try /etc/ssl/ca-bundle.pem
    add_ro_bind_try /etc/pki/tls/cacert.pem
    add_ro_bind_try /etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem
    add_ro_bind_try /etc/ssl/cert.pem
}

print_info_header() {
    # Suite-internal +I contract: wrappers may parse this block of "skn: "
    # lines, which includes exactly one network line. The block ends at EOF.
    printf 'skn: sandboxed command: %s\n' "$(quote_shell_words "$cmd" "${command_args[@]}" "$@")"

    if ((network)); then
        echo "skn: network enabled"
    else
        echo "skn: network disabled"
    fi

    if ((preserve_env)); then
        echo "skn: environment preserved"
    else
        echo "skn: environment mostly cleared"
    fi

    printf 'skn: equivalent invocation: %s\n' "$(quote_shell_words "$progname" "$cmd" "${skn_option_args[@]}" -- "${command_args[@]}" "$@")"
}

if (($# == 0)); then
    usage
    exit 0
fi

case $1 in
    -h|--help)
        usage
        exit 0
        ;;
esac

cmd=$1
shift

if [[ -z $cmd ]]; then
    echo "$progname: empty COMMAND" >&2
    offer_help_and_exit
fi

case $cmd in
    +[A-Z]*)
        echo "$progname: COMMAND comes before skn options; got '$cmd' as COMMAND" >&2
        offer_help_and_exit
        ;;
esac

network=0
preserve_env=0
show_mode=0
info_mode=0
command_args=()
skn_option_args=()
env_queue=()
bind_queue=()
bwrap_args=()
bwrap_display_lines=()

queue_env_ro_binds

# Parse wrapper options. The remaining arguments are for the command.
#
# Note: if we ever decide to support further optional sandbox relaxations, let
# us consider adding a master option (perhaps +X for relax), e.g. +X ipc.  The
# current +N and +P can then remain aliases for, respectively, +X net and +X
# env.
while (($#)); do
    case $1 in
        --)
            shift
            break
            ;;
        +N)
            network=1
            skn_option_args+=(+N)
            shift
            continue
            ;;
        +P)
            preserve_env=1
            skn_option_args+=(+P)
            shift
            continue
            ;;
        +S)
            show_mode=1
            shift
            continue
            ;;
        +I)
            info_mode=1
            shift
            continue
            ;;
        +R|+W|+T)
            option=$1
            if (($# < 2)); then
                echo "$progname: missing argument for $option" >&2
                offer_help_and_exit
            fi
            path=$2
            shift 2
            ;;
        +R?*|+W?*|+T?*)
            option=${1:0:2}
            path=${1:2}
            shift
            ;;
        +E)
            if (($# < 2)); then
                echo "$progname: missing argument for +E" >&2
                offer_help_and_exit
            fi
            queue_env "$2"
            skn_option_args+=(+E "$2")
            shift 2
            continue
            ;;
        +E?*)
            assignment=${1:2}
            queue_env "$assignment"
            skn_option_args+=(+E "$assignment")
            shift
            continue
            ;;
        +A)
            if (($# < 2)); then
                echo "$progname: missing argument for +A" >&2
                offer_help_and_exit
            fi
            command_args+=("$2")
            shift 2
            continue
            ;;
        +A?*)
            command_args+=("${1:2}")
            shift
            continue
            ;;
        +[A-Z]*)
            echo "$progname: reserved skn option: $1" >&2
            echo "$progname: use -- before command arguments that start with +<uppercase>" >&2
            offer_help_and_exit
            ;;
        *)
            break
            ;;
    esac

    queue_bind "$option" "$path" 1
    skn_option_args+=("$option" "$path")
done

if ((info_mode)); then
    print_info_header "$@"
    exit 0
fi

if ((! show_mode)) && [[ -z ${SKN_PATH_CHECK:-} ]]; then
    echo "$progname: SKN_PATH_CHECK is not set" >&2
    offer_help_and_exit
fi

add_base_bwrap_setup

if ((network)); then
    add_network_bwrap_setup
    add_bwrap_args --share-net
fi

add_queued_binds

add_bwrap_args --remount-ro /

if ((preserve_env)); then
    add_queued_envs
else
    add_bwrap_args --clearenv
    add_bwrap_args --setenv SHELL /bin/bash

    # Preserve selected environment variables.
    for key in PATH HOME USER LOGNAME TERM COLORTERM LANG "${!LC_@}"; do
        [[ -v $key ]] && add_bwrap_args --setenv "$key" "${!key}"
    done

    add_queued_envs
fi

if ((show_mode)); then
    print_info_header "$@"
    echo "skn: resulting bwrap invocation:"
    print_bwrap_command "$cmd" "${command_args[@]}" "$@"
    exit 0
fi

exec bwrap \
    "${bwrap_args[@]}" \
    -- \
    "$cmd" \
    "${command_args[@]}" \
    "$@"
