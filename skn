#!/bin/bash

set -euo pipefail

progname="${0##*/}"

usage() {
    cat <<EOF
Usage: $progname COMMAND [skn-options] [--] [COMMAND-args...]

Run COMMAND inside a bwrap sandbox intended for untrusted code. The sandbox
has a private /tmp, a mostly cleared environment unless +P is used, and no
network access unless enabled with +N.

The only host data bound by default is /usr and a few selected parts of /etc,
all read-only. Other host data is not visible unless explicitly bound into the
sandbox with +R/+W/+T or configured through SKN_RO_BINDS/SKN_BINDS. When not
using +S, paths provided through +R/+W/+T are validated by the mandatory
SKN_PATH_CHECK command.

The skn command line interface is unusual: the command to be sandboxed comes
first, followed by skn's own + options and then the command's arguments. This
keeps aliases and small wrappers transparent while putting skn's controls in a
separate namespace from ordinary command options. For example

alias foo='skn foo'

Now, the foo alias will behave almost like the unwrapped foo command, only that
it will run wrapped, and accept a few additional + options (if given at the
beginning). If the unwrapped foo needs an argument that looks like a skn option,
it can be given after another command argument, or -- can be used.

skn-options:
  +R PATH         bind PATH read-only into the sandbox
  +W PATH         bind PATH writable into the sandbox
  +T PATH         bind directory PATH transient-writable; writes are discarded
  +E VAR=VALUE    set environment VAR to VALUE inside the sandbox
  +A ARG          prepend ARG to COMMAND arguments
  +N              enable network access
  +P              preserve caller environment instead of clearing it
  +S              show the sandbox plan after parsing, then exit
  --              stop parsing skn options

Environment:
  SKN_PATH_CHECK  mandatory unless +S is used; command used to validate paths
                  from +R/+W/+T; executed directly with the path as its only
                  argument. Set to 'true' to disable.
  SKN_RO_BINDS    colon-separated paths to bind read-only
  SKN_BINDS       colon-separated paths to bind writable
EOF
}

quote_shell_words() {
    local arg quoted out='' sep=''

    for arg in "$@"; do
        printf -v quoted '%q' "$arg"
        out+="$sep$quoted"
        sep=' '
    done

    printf '%s' "$out"
}

print_shell_words() {
    local indent=$1
    local suffix=$2
    shift 2

    printf '%s%s%s\n' "$indent" "$(quote_shell_words "$@")" "$suffix"
}

add_bwrap() {
    bwrap_args+=("$@")
    bwrap_display_lines+=("$(quote_shell_words "$@")")
}

print_bwrap_command() {
    local continuation line

    printf -v continuation " %b" "\\\\"
    print_shell_words '  ' "$continuation" bwrap

    for line in "${bwrap_display_lines[@]}"; do
        printf '    %s%s\n' "$line" "$continuation"
    done

    print_shell_words '    ' "$continuation" --
    print_shell_words '    ' '' "$@"
}

add_env() {
    local assignment=$1
    local name value

    if [[ $assignment != *=* ]]; then
        echo "$progname: Invalid argument for +E: expected VAR=VALUE" >&2
        usage >&2
        exit 2
    fi

    name=${assignment%%=*}
    value=${assignment#*=}

    if [[ ! $name =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
        echo "$progname: Invalid environment variable name for +E: $name" >&2
        exit 2
    fi

    env_set_pairs+=("$name" "$value")
}

add_env_overrides() {
    local i

    for ((i = 0; i < ${#env_set_pairs[@]}; i += 2)); do
        add_bwrap --setenv "${env_set_pairs[i]}" "${env_set_pairs[i + 1]}"
    done
}

check_path() {
    local label=$1
    local path=$2

    "$SKN_PATH_CHECK" "$path" || {
        echo "$progname: SKN_PATH_CHECK rejected $path ($label) for sharing with sandbox" >&2
        exit 2
    }
}

add_ro_bind_if_exists() {
    local path=$1

    if [[ -e $path ]]; then
        add_bwrap --ro-bind "$path" "$path"
    fi
}

queue_bind() {
    local option=$1
    local path=$2
    local needs_check=${3:-0}

    if [[ -z $path ]]; then
        echo "$progname: Empty path for $option" >&2
        exit 2
    fi

    bind_queue+=("$option" "$path" "$needs_check")
}

emit_bind() {
    local option=$1
    local path=$2
    local needs_check=$3
    local abs_path realpath_args

    if ((show_mode)); then
        realpath_args=(-s -m)
    else
        if [[ $needs_check == 1 ]]; then
            check_path "$option option" "$path"
        fi
        realpath_args=(-s -e)
    fi

    abs_path=$(realpath "${realpath_args[@]}" -- "$path") || {
        echo "$progname: Invalid path for $option: $path" >&2
        exit 2
    }

    case $option in
        +R) add_bwrap --ro-bind "$abs_path" "$abs_path" ;;
        +W) add_bwrap --bind "$abs_path" "$abs_path" ;;
        +T)
            if ((! show_mode)) && [[ ! -d $abs_path ]]; then
                echo "$progname: +T requires an existing directory: $path" >&2
                exit 2
            fi
            add_bwrap --overlay-src "$abs_path" --tmp-overlay "$abs_path"
            ;;
        *)
            echo "$progname: Internal error: invalid bind option: $option" >&2
            exit 2
            ;;
    esac
}

emit_queued_binds() {
    local i

    for ((i = 0; i < ${#bind_queue[@]}; i += 3)); do
        emit_bind "${bind_queue[i]}" "${bind_queue[i + 1]}" "${bind_queue[i + 2]}"
    done
}

queue_env_binds() {
    local var_name=$1
    local option=$2
    local value path

    [[ -v $var_name ]] || return 0
    value=${!var_name}
    [[ -n $value ]] || return 0

    while [[ $value == *:* ]]; do
        path=${value%%:*}
        queue_bind "$option" "$path" 0
        value=${value#*:}
    done

    queue_bind "$option" "$value" 0
}

if (($# == 0)); then
    usage >&2
    exit 2
fi

case $1 in
    -h|--help)
        usage
        exit 0
        ;;
esac

cmd=$1
shift

if [[ -z $cmd ]]; then
    echo "$progname: Empty COMMAND" >&2
    usage >&2
    exit 2
fi

case $cmd in
    +N|+P|+S|+R|+W|+T|+E|+A|+R?*|+W?*|+T?*|+E?*|+A?*)
        echo "$progname: COMMAND comes before skn options; got '$cmd' as COMMAND" >&2
        exit 2
        ;;
esac

network=0
preserve_env=0
show_mode=0
command_args=()
env_set_pairs=()
bind_queue=()
bwrap_args=()
bwrap_display_lines=()

add_bwrap --unshare-all
add_bwrap --new-session
add_bwrap --die-with-parent

# Basic runtime filesystem
add_bwrap --ro-bind /usr /usr
add_bwrap --symlink usr/bin /bin
add_bwrap --symlink usr/lib /lib
add_bwrap --symlink usr/lib64 /lib64
add_bwrap --proc /proc
add_bwrap --dev /dev
add_bwrap --tmpfs /tmp
add_ro_bind_if_exists /etc/alternatives
add_ro_bind_if_exists /etc/ssl/certs
add_ro_bind_if_exists /etc/resolv.conf
add_ro_bind_if_exists /etc/manpath.config

queue_env_binds SKN_RO_BINDS +R
queue_env_binds SKN_BINDS +W

# Parse wrapper options. The remaining arguments are for the command.
while (($#)); do
    case $1 in
        --)
            shift
            break
            ;;
        +N)
            network=1
            add_bwrap --share-net
            shift
            continue
            ;;
        +P)
            preserve_env=1
            shift
            continue
            ;;
        +S)
            show_mode=1
            shift
            continue
            ;;
        +R|+W|+T)
            option=$1
            if (($# < 2)); then
                echo "$progname: Missing argument for $option" >&2
                exit 2
            fi
            path=$2
            shift 2
            ;;
        +R?*|+W?*|+T?*)
            option=${1:0:2}
            path=${1:2}
            shift
            ;;
        +E)
            if (($# < 2)); then
                echo "$progname: Missing argument for +E" >&2
                exit 2
            fi
            add_env "$2"
            shift 2
            continue
            ;;
        +E?*)
            add_env "${1:2}"
            shift
            continue
            ;;
        +A)
            if (($# < 2)); then
                echo "$progname: Missing argument for +A" >&2
                exit 2
            fi
            command_args+=("$2")
            shift 2
            continue
            ;;
        +A?*)
            command_args+=("${1:2}")
            shift
            continue
            ;;
        *)
            break
            ;;
    esac

    queue_bind "$option" "$path" 1
done

if ((! show_mode)) && [[ -z ${SKN_PATH_CHECK:-} ]]; then
    echo "$progname: SKN_PATH_CHECK is not set" >&2
    usage >&2
    exit 2
fi

emit_queued_binds

add_bwrap --remount-ro /

if ((preserve_env)); then
    add_env_overrides
else
    add_bwrap --clearenv
    add_bwrap --setenv SHELL /bin/bash

    # Preserve selected environment variables.
    for key in PATH HOME USER LOGNAME TERM COLORTERM LANG "${!LC_@}"; do
        [[ -v $key ]] && add_bwrap --setenv "$key" "${!key}"
    done

    add_env_overrides
fi

if ((show_mode)); then
    # Suite-internal contract: wrappers may parse this initial block of
    # "skn: " lines, which includes exactly one network line. The block ends
    # at the first line not starting with "skn: ".
    printf 'skn: command: %s\n' "$(quote_shell_words "$cmd" "${command_args[@]}" "$@")"

    if ((network)); then
        echo "skn: network enabled"
    else
        echo "skn: network disabled"
    fi

    if ((preserve_env)); then
        echo "skn: environment preserved"
    else
        echo "skn: environment mostly cleared"
    fi

    echo "skn: bwrap command:"
    print_bwrap_command "$cmd" "${command_args[@]}" "$@"
    exit 0
fi

exec bwrap \
    "${bwrap_args[@]}" \
    -- \
    "$cmd" \
    "${command_args[@]}" \
    "$@"
