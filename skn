#!/bin/bash

set -euo pipefail

progname="${0##*/}"

usage() {
    cat <<EOF
Usage: $progname COMMAND [skn-options] [--] [COMMAND-args...]

Run COMMAND inside a bwrap sandbox intended for untrusted code. The sandbox
has a private /tmp, a neutral hostname, a mostly cleared environment unless
+E is used, and no network access unless enabled with +N.

The skn command line interface is unusual: the command to be sandboxed comes
first, followed by skn's own + options and then the command's arguments. This
keeps aliases and small wrappers transparent while putting skn's controls in a
separate namespace from ordinary command options. For example

alias foo='skn foo'

Now, the foo alias behaves almost like the unwrapped foo command, except that
it runs sandboxed and accepts skn + options before the wrapped command's own
arguments. If the unwrapped foo needs an argument that looks like a skn option,
it can be given after another command argument, or -- can be used.

The only host data bound by default is /usr, optional system runtime paths
such as /bin and /lib, and a few selected parts of /etc, all read-only. DNS
configuration and common public CA root locations are added only with +N.
Other host data is not visible unless explicitly bound into the sandbox with
+R/+W/+T or configured read-only through SKN_RO_BINDS. When not using +S or
+0, paths provided through +R/+W/+T are validated by the mandatory
SKN_PATH_CHECK command.

skn-options:
  +R PATH         bind PATH read-only into the sandbox
  +W PATH         bind PATH writable into the sandbox
  +T PATH         bind directory PATH transient-writable; writes are discarded
  +V VAR          pass environment VAR into the sandbox if it is set
  +V VAR=VALUE    set environment VAR to VALUE inside the sandbox
  +A ARG          prepend ARG to COMMAND arguments
  +N              enable network access
  +E              preserve caller environment instead of clearing it
  +S              show the sandbox plan after parsing, then exit
  +0              emit machine-readable parsed info (for wrappers), then exit
  --              stop parsing skn options

While skn is parsing options, unrecognized +<uppercase> forms are reserved
for future skn options; use -- before command arguments that look like that.

Environment:
  SKN_PATH_CHECK  mandatory unless +S or +0 is used; command used to validate
                  paths from +R/+W/+T; executed directly with the path as its
                  only argument. Set to 'true' to disable.
  SKN_RO_BINDS    colon-separated absolute paths to bind read-only
  SKN_PASS_VARS   colon-separated variable names to pass when set

Nested skn invocations are supported: skn sets SKN_PATH_CHECK=true inside the
sandbox and preserves SKN_RO_BINDS and SKN_PASS_VARS if set. Explicit +V options
and SKN_PASS_VARS entries take precedence over these nested defaults.
EOF
}

error() {
    echo "$progname: $*" >&2
    echo "Try '$progname --help' for more information." >&2
    exit 2
}

quote_shell_words() {
    local arg quoted out='' sep=''

    for arg in "$@"; do
        printf -v quoted '%q' "$arg"
        out+="$sep$quoted"
        sep=' '
    done

    printf '%s' "$out"
}

print_shell_words() {
    local indent=$1
    local suffix=$2
    shift 2

    printf '%s%s%s\n' "$indent" "$(quote_shell_words "$@")" "$suffix"
}

add_bwrap_args() {
    bwrap_args+=("$@")
    bwrap_display_lines+=("$(quote_shell_words "$@")")
}

add_ro_bind_try() {
    local path=$1

    add_bwrap_args --ro-bind-try "$path" "$path"
}

print_bwrap_command() {
    local continuation line

    printf -v continuation " %b" "\\\\"
    print_shell_words '  ' "$continuation" bwrap

    for line in "${bwrap_display_lines[@]}"; do
        printf '    %s%s\n' "$line" "$continuation"
    done

    print_shell_words '    ' "$continuation" --
    print_shell_words '    ' '' "$@"
}

valid_env_name() {
    [[ $1 =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]
}

load_original_env() {
    local entry name value

    ((env_loaded)) && return 0

    # Read the process’s original environment directly. This avoids collisions
    # with shell variables used internally by this script, including lowercase
    # environment names and Bash’s own special variables.
    while IFS= read -r -d '' entry; do
        name=${entry%%=*}
        value=${entry#*=}
        env_present["$name"]=1
        env_values["$name"]=$value
    done </proc/$$/environ

    env_loaded=1
}

lookup_original_env() {
    local name=$1

    load_original_env
    env_value=

    if [[ ${env_present[$name]+set} ]]; then
        env_value=${env_values[$name]}
        return 0
    fi

    return 1
}

read_original_env_command() {
    local entry

    exec_cmd=(env -i)
    while IFS= read -r -d '' entry; do
        exec_cmd+=("$entry")
    done </proc/$$/environ
    exec_cmd+=(bwrap)
}

queue_env_spec() {
    local spec=$1
    local name value

    if [[ $spec == *=* ]]; then
        name=${spec%%=*}
        value=${spec#*=}
        valid_env_name "$name" || error "invalid environment variable name for +V: $name"
        env_queue+=(set "$name" "$value")
    else
        name=$spec
        valid_env_name "$name" || error "invalid environment variable name for +V: $name"
        env_queue+=(pass "$name" '')
    fi
}

add_queued_envs() {
    local mode name value i
    local -A env_overridden=()

    for ((i = 0; i < ${#env_queue[@]}; i += 3)); do
        mode=${env_queue[i]}
        name=${env_queue[i + 1]}
        value=${env_queue[i + 2]}

        case $mode in
            set)
                add_bwrap_args --setenv "$name" "$value"
                env_overridden["$name"]=1
                ;;
            pass)
                if ((preserve_env)) && [[ ! ${env_overridden[$name]+set} ]]; then
                    continue
                fi

                if lookup_original_env "$name"; then
                    add_bwrap_args --setenv "$name" "$env_value"
                elif [[ ${env_overridden[$name]+set} ]]; then
                    add_bwrap_args --unsetenv "$name"
                fi
                unset "env_overridden[$name]"
                ;;
        esac
    done
}

env_queued() {
    local name=$1
    local i

    for ((i = 0; i < ${#env_queue[@]}; i += 3)); do
        [[ ${env_queue[i + 1]} == "$name" ]] && return 0
    done

    return 1
}

add_nested_skn_env() {
    if ! env_queued SKN_PATH_CHECK; then
        add_bwrap_args --setenv SKN_PATH_CHECK true
    fi

    if [[ -v SKN_RO_BINDS ]] && ! env_queued SKN_RO_BINDS; then
        add_bwrap_args --setenv SKN_RO_BINDS "$SKN_RO_BINDS"
    fi

    if [[ -v SKN_PASS_VARS ]] && ! env_queued SKN_PASS_VARS; then
        add_bwrap_args --setenv SKN_PASS_VARS "$SKN_PASS_VARS"
    fi
}

check_path() {
    local label=$1
    local path=$2

    if ! "$SKN_PATH_CHECK" "$path"; then
        echo "$progname: SKN_PATH_CHECK rejected $path ($label) for sharing with sandbox" >&2
        path_check_failed=1
    fi
}

queue_bind() {
    local option=$1
    local path=$2
    local needs_check=${3:-0}

    [[ -n $path ]] || error "empty path for $option"

    bind_queue+=("$option" "$path" "$needs_check")
}

add_bind() {
    local option=$1
    local path=$2
    local needs_check=$3
    local abs_path realpath_args

    if ((show_mode)); then
        realpath_args=(-s -m)
    else
        if [[ $needs_check == 1 ]]; then
            check_path "$option option" "$path"
        fi
        realpath_args=(-s -e)
    fi

    abs_path=$(realpath "${realpath_args[@]}" -- "$path") || error "invalid path for $option: $path"

    case $option in
        +R) add_bwrap_args --ro-bind "$abs_path" "$abs_path" ;;
        +W) add_bwrap_args --bind "$abs_path" "$abs_path" ;;
        +T)
            ((show_mode)) || [[ -d $abs_path ]] || error "+T requires an existing directory: $path"
            add_bwrap_args --overlay-src "$abs_path" --tmp-overlay "$abs_path"
            ;;
        *)
            echo "$progname: internal error: invalid bind option: $option" >&2
            exit 2
            ;;
    esac
}

add_queued_binds() {
    local i

    path_check_failed=0

    for ((i = 0; i < ${#bind_queue[@]}; i += 3)); do
        add_bind "${bind_queue[i]}" "${bind_queue[i + 1]}" "${bind_queue[i + 2]}"
    done

    if ((path_check_failed)); then
        echo "Try '$progname --help' for more information." >&2
        exit 2
    fi
}

queue_env_ro_bind() {
    local path=$1

    [[ -n $path ]] || error "empty path in SKN_RO_BINDS"
    [[ $path == /* ]] || error "SKN_RO_BINDS entries must be absolute paths: $path"

    queue_bind +R "$path" 0
}

queue_colon_list() {
    local value=$1
    local callback=$2
    local item

    [[ -n $value ]] || return 0

    while [[ $value == *:* ]]; do
        item=${value%%:*}
        "$callback" "$item"
        value=${value#*:}
    done

    "$callback" "$value"
}

queue_env_ro_binds() {
    [[ -v SKN_RO_BINDS ]] || return 0
    queue_colon_list "$SKN_RO_BINDS" queue_env_ro_bind
}

queue_pass_var_name() {
    local name=$1

    [[ -n $name ]] || error "empty variable name in SKN_PASS_VARS"
    valid_env_name "$name" || error "SKN_PASS_VARS entries must be variable names, not assignments: $name"

    env_queue+=(pass "$name" '')
}

queue_pass_vars() {
    [[ -v SKN_PASS_VARS ]] || return 0
    queue_colon_list "$SKN_PASS_VARS" queue_pass_var_name
}

add_base_bwrap_setup() {
    local path

    add_bwrap_args --unshare-all
    add_bwrap_args --hostname skn
    add_bwrap_args --new-session
    add_bwrap_args --die-with-parent

    # Basic runtime filesystem
    add_bwrap_args --proc /proc
    add_bwrap_args --dev /dev
    add_bwrap_args --tmpfs /tmp
    add_bwrap_args --ro-bind /usr /usr
    add_ro_bind_try /bin
    add_ro_bind_try /sbin
    add_ro_bind_try /lib
    add_ro_bind_try /lib64
    add_ro_bind_try /lib32

    # Optional distro/system integration files. These are deliberately narrow
    # read-only binds; missing paths are ignored by bubblewrap.
    add_ro_bind_try /etc/alternatives
    add_ro_bind_try /etc/manpath.config
    add_ro_bind_try /etc/man_db.conf
    add_ro_bind_try /etc/man.conf
}

add_network_bwrap_setup() {
    add_ro_bind_try /etc/resolv.conf

    # Common public CA root locations, based on Go’s Linux x509 search paths.
    # Bind certificate directories as directories, and bind bundle-file paths
    # that are not covered by those directory binds separately.
    add_ro_bind_try /etc/ssl/certs
    add_ro_bind_try /etc/pki/tls/certs
    add_ro_bind_try /etc/ssl/ca-bundle.pem
    add_ro_bind_try /etc/pki/tls/cacert.pem
    add_ro_bind_try /etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem
    add_ro_bind_try /etc/ssl/cert.pem
}

print_info_header() {
    printf 'skn: sandboxed command: %s\n' "$(quote_shell_words "$cmd" "${command_args[@]}" "$@")"

    if ((network)); then
        echo "skn: network enabled"
    else
        echo "skn: network disabled"
    fi

    if ((preserve_env)); then
        echo "skn: environment preserved"
    else
        echo "skn: environment mostly cleared"
    fi

    printf 'skn: equivalent invocation: %s\n' "$(quote_shell_words "$progname" "$cmd" "${skn_option_args[@]}" -- "${command_args[@]}" "$@")"
}

print_machine_info() {
    local argc

    argc=$((1 + ${#command_args[@]} + $#))

    printf 'format: skn-info-mk1\n'
    if ((network)); then
        printf 'network: enabled\n'
    else
        printf 'network: disabled\n'
    fi

    if ((preserve_env)); then
        printf 'environment: preserved\n'
    else
        printf 'environment: cleared\n'
    fi

    printf 'argc: %d\n' "$argc"
    printf '\n'
    printf '%s\0' "$cmd" "${command_args[@]}" "$@"
}

if (($# == 0)); then
    usage
    exit 0
fi

case $1 in
    -h|--help)
        usage
        exit 0
        ;;
esac

cmd=$1
shift

[[ -n $cmd ]] || error "empty COMMAND"

case $cmd in
    +[A-Z]*) error "COMMAND comes before skn options; got '$cmd' as COMMAND" ;;
esac

network=0
preserve_env=0
show_mode=0
machine_mode=0
command_args=()
skn_option_args=()
env_queue=()
bind_queue=()
bwrap_args=()
bwrap_display_lines=()
env_loaded=0
declare -A env_present=()
declare -A env_values=()

queue_env_ro_binds
queue_pass_vars

# Parse wrapper options. The remaining arguments are for the command.
#
# Note: if we ever decide to support further optional sandbox relaxations, let
# us consider adding a master option (perhaps +X for relax), e.g. +X ipc.  The
# current +N and +E can then remain aliases for, respectively, +X net and +X
# env.
while (($#)); do
    case $1 in
        --)
            shift
            break
            ;;
        +N)
            network=1
            skn_option_args+=(+N)
            shift
            continue
            ;;
        +E)
            preserve_env=1
            skn_option_args+=(+E)
            shift
            continue
            ;;
        +S)
            show_mode=1
            shift
            continue
            ;;
        +0)
            machine_mode=1
            shift
            continue
            ;;
        +R|+W|+T)
            option=$1
            (($# >= 2)) || error "missing argument for $option"
            path=$2
            shift 2
            ;;
        +R?*|+W?*|+T?*)
            option=${1:0:2}
            path=${1:2}
            shift
            ;;
        +V)
            (($# >= 2)) || error "missing argument for +V"
            queue_env_spec "$2"
            skn_option_args+=(+V "$2")
            shift 2
            continue
            ;;
        +V?*)
            env_spec=${1:2}
            queue_env_spec "$env_spec"
            skn_option_args+=(+V "$env_spec")
            shift
            continue
            ;;
        +A)
            (($# >= 2)) || error "missing argument for +A"
            command_args+=("$2")
            shift 2
            continue
            ;;
        +A?*)
            command_args+=("${1:2}")
            shift
            continue
            ;;
        +[A-Z]*)
            echo "$progname: reserved skn option: $1" >&2
            error "use -- before command arguments that start with +<uppercase>"
            ;;
        *)
            break
            ;;
    esac

    queue_bind "$option" "$path" 1
    skn_option_args+=("$option" "$path")
done

if ((machine_mode)); then
    print_machine_info "$@"
    exit 0
fi

((show_mode)) || [[ -n ${SKN_PATH_CHECK:-} ]] || error "SKN_PATH_CHECK is not set"

add_base_bwrap_setup

if ((network)); then
    add_network_bwrap_setup
    add_bwrap_args --share-net
fi

add_queued_binds

add_bwrap_args --remount-ro /

if ((preserve_env)); then
    add_queued_envs
else
    add_bwrap_args --clearenv
    add_bwrap_args --setenv SHELL /bin/bash

    # Preserve selected environment variables.
    for key in PATH HOME USER LOGNAME TERM COLORTERM LANG "${!LC_@}"; do
        [[ -v $key ]] && add_bwrap_args --setenv "$key" "${!key}"
    done

    # Make nested skn invocations work with the same already-exposed filesystem
    # baseline, without preserving the whole caller environment.
    add_nested_skn_env

    add_queued_envs
fi

if ((show_mode)); then
    print_info_header "$@"
    echo "skn: resulting bwrap invocation:"
    print_bwrap_command "$cmd" "${command_args[@]}" "$@"
    exit 0
fi

if ((preserve_env)); then
    read_original_env_command
else
    exec_cmd=(bwrap)
fi

exec "${exec_cmd[@]}" \
    "${bwrap_args[@]}" \
    -- \
    "$cmd" \
    "${command_args[@]}" \
    "$@"
