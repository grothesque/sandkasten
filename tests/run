#!/bin/bash

set -euo pipefail

repo_root=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
cd "$repo_root"

shell_files=(
    ./skn
    ./rust/skn-cargo
    ./rust/skn-rust-analyzer
    ./tests/run
    ./tests/helpers/common.bash
    ./tests/*.bats
)

bash -n "${shell_files[@]}"

if command -v shellcheck >/dev/null 2>&1; then
    shellcheck "${shell_files[@]}"
else
    echo 'tests/run: shellcheck not found; skipping shellcheck' >&2
fi

if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git diff --check -- .
fi

if ! command -v bats >/dev/null 2>&1; then
    echo 'tests/run: bats not found' >&2
    exit 127
fi

bats tests
