#!/bin/bash
#
# Run a command with a usable TTY and an inspection shell.
#
# This is intended for interactive full-screen tools such as Pi, Emacs, htop,
# REPLs, and debuggers.  A private tmux session provides the PTY and job
# control for tools that expect /dev/tty.

set -euo pipefail

progname=with-tty

usage() {
    cat <<EOF
Usage: $progname COMMAND [COMMAND-args...]

Run COMMAND with a usable controlling TTY.  COMMAND is started by an
interactive shell inside a private tmux session: success with no visible output
after the last Enter or Ctrl-D exits, as does success with a blank pane.
Visible output, failure, or suspension leaves the shell for inspection.  If
the tmux client is detached, with-tty reattaches while the session still exists.
The default tmux suspend key binding is disabled.
EOF
}

if (($# == 0)); then
    usage
    exit 0
fi

case $1 in
    -h|--help)
        usage
        exit 0
        ;;
esac

# Use an interactive Bash inside a private tmux session both to launch the
# command with normal job control and to become the inspection shell afterwards.
# The command is scheduled from PROMPT_COMMAND rather than run directly from
# the rcfile body, so suspended jobs can be managed reliably with jobs/fg in
# that same shell.
# Use -S so each invocation gets an isolated tmux server whose socket is
# cleaned up with the temporary directory.
tmpdir=$(mktemp -d /tmp/with-tty.XXXXXXXXXX) || exit 2
tmux_socket=$tmpdir/socket
trap 'tmux -S "$tmux_socket" kill-server 2>/dev/null || true; rm -rf -- "$tmpdir"' EXIT

rcfile=$tmpdir/bashrc

{
    printf 'with_tty_socket=%q\n' "$tmux_socket"
    printf 'with_tty_pane_before=%q\n' "$tmpdir/pane-before"
    printf 'with_tty_pane_after=%q\n' "$tmpdir/pane-after"
    printf 'with_tty_pane_last_input=%q\n' "$tmpdir/pane-last-input"
    cat <<'EOF'
# Save the original argv.  PROMPT_COMMAND invokes a function, where "$@" would
# otherwise mean that function's arguments rather than the command to run.
with_tty_command=("$@")

with_tty_capture_pane() {
    tmux -S "$with_tty_socket" capture-pane -p -S - -E - >"$1" 2>/dev/null
}

with_tty_has_single_pane() {
    local pane_count

    pane_count=$(tmux -S "$with_tty_socket" list-panes -a -F '#{pane_id}' 2>/dev/null | wc -l) || return 2
    ((pane_count == 1))
}

with_tty_pane_has_visible_change() {
    if ! with_tty_capture_pane "$with_tty_pane_after"; then
        return 2
    fi

    if [[ -e $with_tty_pane_last_input ]] && cmp -s "$with_tty_pane_last_input" "$with_tty_pane_after"; then
        return 1
    fi

    if ((with_tty_pane_before_status == 0)) && cmp -s "$with_tty_pane_before" "$with_tty_pane_after"; then
        return 1
    fi

    if grep -q '[^[:space:]]' "$with_tty_pane_after"; then
        return 0
    fi

    return 1
}

with_tty_main() {
    unset PROMPT_COMMAND

    with_tty_capture_pane "$with_tty_pane_before"
    with_tty_pane_before_status=$?

    "${with_tty_command[@]}"
    with_tty_status=$?

    if ((with_tty_status == 0)); then
        with_tty_visible_status=0

        # Auto-close only while this still looks like a wrapper-owned tmux: one
        # pane total.  If the user creates panes or windows, assume they have
        # taken manual control of the private tmux session and leave it open.
        with_tty_has_single_pane || with_tty_visible_status=3

        if ((with_tty_visible_status == 0)); then
            with_tty_pane_has_visible_change || with_tty_visible_status=$?
        fi

        if ((with_tty_visible_status == 1)); then
            exit 0
        fi
    fi

    if ((with_tty_status == 0)); then
        if ((with_tty_visible_status == 2)); then
            printf '\nwith-tty: could not inspect pane contents; leaving shell for inspection.\n' >&2
        elif ((with_tty_visible_status == 3)); then
            printf '\nwith-tty: additional tmux panes exist; leaving shell open.\n' >&2
        else
            printf '\nwith-tty: command left visible output; leaving shell for inspection.\n' >&2
        fi
        printf 'with-tty: use exit to end the session.\n' >&2
    else
        printf '\nwith-tty: command failed or stopped with status %d; leaving shell for inspection.\n' "$with_tty_status" >&2
        printf 'with-tty: use jobs/fg for stopped jobs; use exit N to choose the final status.\n' >&2
    fi
}

PROMPT_COMMAND=with_tty_main
EOF
} >"$rcfile"

set +e
pane_last_input=$tmpdir/pane-last-input
tmux_buffer=with-tty-last-input
# Enter and Ctrl-D are common final inputs for REPLs and agents.  Snapshot the
# pane before forwarding them, so a quiet exit afterwards can close tmux even
# when the program left a banner or prompt from earlier interaction.
capture_last_input="capture-pane -b '$tmux_buffer' -S - -E - ; save-buffer -b '$tmux_buffer' '$pane_last_input' ; delete-buffer -b '$tmux_buffer'"

tmux -S "$tmux_socket" \
    set-option -g status-left-length 20 \; \
    set-option -g status-style 'fg=black,bg=colour248' \; \
    bind-key -n Enter "$capture_last_input ; send-keys Enter" \; \
    bind-key -n C-d "$capture_last_input ; send-keys C-d" \; \
    bind-key C-z display-message -d 2000 'with-tty: suspend disabled' \; \
    new-session -s with-tty -- /bin/bash --rcfile "$rcfile" -i -s -- "$@"
status=$?

reattach_message='with-tty: reattached after detach; use exit to end the session'
while tmux -S "$tmux_socket" has-session -t with-tty 2>/dev/null; do
    (
        # attach-session blocks the wrapper, so poll in the background until
        # the new client exists and can receive the reattach message.
        for ((poll_attempt = 0; poll_attempt < 10; poll_attempt++)); do
            reattach_client=$(tmux -S "$tmux_socket" list-clients -t with-tty -F '#{client_tty}' 2>/dev/null | head -n 1)
            if [[ -n $reattach_client ]]; then
                tmux -S "$tmux_socket" display-message -d 2000 -c "$reattach_client" "$reattach_message" 2>/dev/null || true
                exit 0
            fi
            sleep 0.1
        done
    ) &
    reattach_message_pid=$!
    tmux -S "$tmux_socket" attach-session -t with-tty
    status=$?
    wait "$reattach_message_pid" 2>/dev/null || true
done

set -e
exit "$status"
